# ============================================
# GROWTHENGINE AI - Environment Configuration
# ============================================
# Copy this file to .env and fill in your keys

# Server
PORT=5000
JWT_SECRET=your-secret-key-here
NODE_ENV=development

# OpenAI (for AI content generation)
OPENAI_API_KEY=sk-your-openai-key

# Facebook / Meta Business Suite
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret
META_ACCESS_TOKEN=your-meta-access-token

# Instagram (via Meta Graph API)
INSTAGRAM_BUSINESS_ACCOUNT_ID=your-ig-account-id

# Google Ads & YouTube
GOOGLE_ADS_CLIENT_ID=your-google-client-id
GOOGLE_ADS_CLIENT_SECRET=your-google-client-secret
GOOGLE_ADS_DEVELOPER_TOKEN=your-developer-token
GOOGLE_ADS_REFRESH_TOKEN=your-refresh-token
YOUTUBE_API_KEY=your-youtube-api-key

# X / Twitter
TWITTER_API_KEY=your-twitter-api-key
TWITTER_API_SECRET=your-twitter-api-secret
TWITTER_ACCESS_TOKEN=your-twitter-access-token
TWITTER_ACCESS_SECRET=your-twitter-access-secret

# LinkedIn
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret
LINKEDIN_ACCESS_TOKEN=your-linkedin-access-token

# TikTok Business
TIKTOK_APP_ID=your-tiktok-app-id
TIKTOK_APP_SECRET=your-tiktok-app-secret
TIKTOK_ACCESS_TOKEN=your-tiktok-access-token

# WhatsApp Business API
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token
WHATSAPP_BUSINESS_ACCOUNT_ID=your-business-account-id

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# ==========================================
# AI MEDIA GENERATION
# ==========================================

# Stability AI (Stable Diffusion)
STABILITY_API_KEY=your-stability-api-key

# Midjourney (via API proxy)
MIDJOURNEY_API_KEY=your-midjourney-api-key
MIDJOURNEY_API_URL=https://api.midjourneyapi.xyz/v2

# Runway ML (Video Generation)
RUNWAY_API_KEY=your-runway-api-key

# Pika Labs (Video Generation)
PIKA_API_KEY=your-pika-api-key

# HeyGen (AI Avatar Videos)
HEYGEN_API_KEY=your-heygen-api-key

# Synthesia (AI Presenter Videos)
SYNTHESIA_API_KEY=your-synthesia-api-key

# ElevenLabs (AI Voice)
ELEVENLABS_API_KEY=your-elevenlabs-api-key

# ==========================================
# CHINESE PLATFORMS (中国平台)
# ==========================================

# WeChat Official Account (微信公众号)
WECHAT_APP_ID=your-wechat-app-id
WECHAT_APP_SECRET=your-wechat-app-secret

# WeChat Marketing API (微信广告)
WECHAT_ADS_TOKEN=your-wechat-ads-token

# Weibo (微博)
WEIBO_APP_KEY=your-weibo-app-key
WEIBO_APP_SECRET=your-weibo-app-secret
WEIBO_ACCESS_TOKEN=your-weibo-access-token

# Douyin / TikTok China (抖音)
DOUYIN_CLIENT_KEY=your-douyin-client-key
DOUYIN_CLIENT_SECRET=your-douyin-client-secret

# Ocean Engine / 巨量引擎 (Douyin Ads)
OCEAN_ENGINE_ADVERTISER_ID=your-advertiser-id
OCEAN_ENGINE_ACCESS_TOKEN=your-ocean-engine-token

# Xiaohongshu / RED (小红书)
XIAOHONGSHU_APP_ID=your-xhs-app-id
XIAOHONGSHU_APP_SECRET=your-xhs-app-secret

# Bilibili (哔哩哔哩)
BILIBILI_ACCESS_KEY=your-bilibili-key

# Baidu Marketing (百度推广)
BAIDU_USERNAME=your-baidu-username
BAIDU_TOKEN=your-baidu-token

# ==========================================
# Webhook & Tracking
# ==========================================
WEBHOOK_SECRET=your-webhook-secret
TRACKING_DOMAIN=https://yourdomain.com
